# ════════════════════════════════════════════════════════════════
# .env.example.worker
# 역할: 이미지 생성 워커 (GCP VM)
# 사용 시나리오:
#   - FastAPI 로 /generate-image 엔드포인트 노출
#   - 자체 GPU 로 diffusers 모델 (SD 1.5, IP-Adapter) 직접 실행
#   - 사용자 UI 는 없음 (워커 전용)
#
# 사용법:
#   cp .env.example.worker .env
#   # 아래 <CHANGE_ME> 들을 채우기
#   uv run uvicorn worker_api:app --host 0.0.0.0 --port 8006
# ════════════════════════════════════════════════════════════════

# ── 앱 환경 ──
APP_ENV=production
LOG_LEVEL=INFO

# ── 이미지 생성 백엔드 ──
# 워커는 자기 GPU 로 직접 돌리니까 hf_local
# remote_worker 는 금지 (자기 자신 호출 → 무한 루프, worker_api.py 에서 가드)
IMAGE_BACKEND_KIND=hf_local

# ── OpenAI (image_service 가 프롬프트 한국어→영문 번역에 사용) ──
# 향후 Stage 3 에서 번역을 app 쪽으로 옮기면 워커는 OpenAI 키 불필요해짐
OPENAI_API_KEY=<CHANGE_ME>
TEXT_MODEL=gpt-5-mini
TEXT_TIMEOUT=30.0

# ── Langfuse (선택: 워커 내부 OpenAI 번역 trace 수집) ──
# 앱과 워커를 둘 다 추적하려면 VM .env 에도 동일하게 넣어야 한다.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── 로컬 diffusers 설정 ──
LOCAL_MODEL_CACHE_DIR=./models/cache
LOCAL_SD15_MODEL_ID=runwayml/stable-diffusion-v1-5
LOCAL_IP_ADAPTER_ID=h94/IP-Adapter
LOCAL_IP_ADAPTER_SUBFOLDER=models
LOCAL_IP_ADAPTER_WEIGHT_NAME=ip-adapter_sd15.bin
LOCAL_INFERENCE_STEPS=30        # 워커는 품질 우선 (느려도 OK)
LOCAL_GUIDANCE_SCALE=7.5
LOCAL_IP_ADAPTER_SCALE=0.6
LOCAL_IMG2IMG_STRENGTH=0.5
LOCAL_BACKEND=ip_adapter        # ip_adapter | img2img | hybrid

# ── 워커 자체 인증 (이 토큰을 가진 클라이언트만 호출 허용) ──
# .env.example.app 의 IMAGE_WORKER_TOKEN 과 같은 값이어야 함
IMAGE_WORKER_TOKEN=<CHANGE_ME_LONG_RANDOM>
IMAGE_WORKER_HOST=0.0.0.0
IMAGE_WORKER_PORT=8006

# ── 워커는 다음 항목을 직접 호출하지 않음 (안 적어도 됨) ──
# IMAGE_WORKER_URL  ← 자기 자신 가리키지 않음
# HUGGINGFACE_API_KEY ← 로컬 모델이라 불필요
# META_ACCESS_TOKEN, INSTAGRAM_ACCOUNT_ID ← 인스타 업로드 안 함
# FREEIMAGE_API_KEY ← 인스타 업로드 안 함
