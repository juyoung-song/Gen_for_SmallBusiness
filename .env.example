# ── AI API Keys ──
# OpenAI API: https://platform.openai.com/
OPENAI_API_KEY=sk-your-openai-api-key-here

# Hugging Face API: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your-huggingface-api-key-here

# FreeImage API (For Meta API image hosting): https://freeimage.host/page/api
FREEIMAGE_API_KEY=your-freeimage-api-key-here

# ── Application Settings ──
APP_ENV=development                       # development | production
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR
USE_MOCK=true                              # true (연습용 모드) / false (실제 API 호출)

# ── AI Model Settings ──
TEXT_MODEL=gpt-5-mini                     # 텍스트 생성용 모델
IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0 # 이미지 생성용 모델
IMAGE_SIZE=1024x1024

# ── Meta/Instagram API Settings ──
# Facebook 시스템 사용자 영구 토큰: https://developers.facebook.com/
META_ACCESS_TOKEN=your-long-lived-access-token-here

# 인스타그램 비즈니스 계정 ID (178...로 시작하는 숫자)
INSTAGRAM_ACCOUNT_ID=your-instagram-account-id-here

# ── Database ──
DATABASE_URL=sqlite+aiosqlite:///./ad_history.db
