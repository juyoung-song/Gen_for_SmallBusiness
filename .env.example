# ── AI API Keys ──
OPENAI_API_KEY=sk-your-openai-api-key-here
HUGGINGFACE_API_KEY=hf-your-huggingface-api-key-here

# ── Application ──
APP_ENV=development
USE_MOCK=false

# ── Model Settings ──
TEXT_MODEL=gpt-5-mini
IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# ── Instagram Upload Settings ──
IMGBB_API_KEY=your-imgbb-api-key-here
META_ACCESS_TOKEN=your-meta-long-lived-access-token-here
INSTAGRAM_ACCOUNT_ID=your-instagram-business-account-id-here
