# ── Meta (Instagram) OAuth 설정 ──
# Meta 개발자 센터에서 발급받은 내용을 입력하세요.

META_APP_ID=714559465013751
META_APP_SECRET=                   # 보안을 위해 비워둡니다. 팀원에게 직접 공유하세요.
META_REDIRECT_URI=http://localhost:8501/

# ── 보안 설정 ──
# 토큰 암호화 키 (32바이트 URL-safe base64 문자열)
# 사장님 .env에 있는 값을 공유해야 팀원 로컬 DB에서도 읽을 수 있습니다.
TOKEN_ENCRYPTION_KEY=

# ── 인스타그램 수동 연결용 (기존 방식) ──
META_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
