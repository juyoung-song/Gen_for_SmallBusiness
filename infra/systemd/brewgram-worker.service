[Unit]
Description=Brewgram worker_api FastAPI
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=spai0608
Group=spai0608
WorkingDirectory=/home/spai0608/Gen_for_SmallBusiness
EnvironmentFile=/etc/brewgram/worker_api.env
ExecStart=/home/spai0608/.local/bin/uv run uvicorn worker_api:app --host 127.0.0.1 --port 8010
Restart=always
RestartSec=5
TimeoutStopSec=20

[Install]
WantedBy=multi-user.target
